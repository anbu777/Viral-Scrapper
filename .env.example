# ═══════════════════════════════════════════════════════════════════════════════
# Social Media AI — Environment Configuration (Example)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in only the keys you need.
#
# 100% FREE setup (recommended starting point):
#   - Get a Gemini API key (free at https://aistudio.google.com/app/apikey)
#   - Install yt-dlp for TikTok / YouTube Shorts:
#       Windows: winget install yt-dlp
#       macOS:   brew install yt-dlp
#       Linux:   pipx install yt-dlp
#   - Set SCRAPER_PROVIDER=manual to import URLs via the /import page.
#   - Leave everything else empty. Edge TTS will be used automatically.
#
# Every other key is OPTIONAL — only fill it if you want to upgrade that stage.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core providers ───────────────────────────────────────────────────────────

# Instagram scraping mode:
#   manual = paste URLs in /import page (no scraping; works without any key) [RECOMMENDED]
#   local  = scrape via headless Playwright (may require a logged-in browser profile)
#   apify  = use Apify (FREEMIUM, ~$5/month free credits)
#   tiktok = TikTok scraping via yt-dlp (FREE, just install yt-dlp)
#   youtube = YouTube Shorts scraping via yt-dlp (FREE, just install yt-dlp)
SCRAPER_PROVIDER=manual

# AI provider for video analysis & script generation:
#   gemini  = Google Gemini 2.5 Flash (FREE, ~1500 req/day)  [RECOMMENDED]
#   claude  = Anthropic Claude (PAID — falls back to Gemini if key missing)
#   ollama  = Local Ollama (FREE, requires local install + decent GPU)
AI_PROVIDER=gemini

# Transcript provider for spoken-word extraction:
#   gemini        = Google Gemini transcription (FREE)  [RECOMMENDED]
#   whisper-local = local Whisper CLI (FREE, heavy on CPU)
TRANSCRIPT_PROVIDER=gemini

# Avatar video generation provider:
#   none = skip avatar video generation (RECOMMENDED for free tier)
#   fal  = use fal.ai (PAID, no meaningful free tier)
VIDEO_PROVIDER=none

# SQLite local DB file, OR a Postgres URL such as
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=file:../data/app.db

# ─── API keys ─────────────────────────────────────────────────────────────────

# [REQUIRED FOR ANALYSIS — FREE] Google Gemini 2.5 Flash.
# Used for video analysis, transcription, concepts, scripts, and consistency check.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [OPTIONAL — PAID] Anthropic Claude. Better quality but the app falls back to
# Gemini automatically when this key is empty.
ANTHROPIC_API_KEY=

# [OPTIONAL — FREEMIUM] Apify Instagram scraper. Only used when SCRAPER_PROVIDER=apify.
APIFY_API_TOKEN=

# [OPTIONAL — PAID] fal.ai for image + video generation. Only used when VIDEO_PROVIDER=fal.
FAL_KEY=

# [OPTIONAL — PAID] ElevenLabs for voice cloning. When empty, the app uses
# Microsoft Edge TTS (FREE, 400+ neural voices, no signup).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# [OPTIONAL — FREE] Override the Edge TTS voice used in fallback mode.
# Examples: en-US-AriaNeural, en-US-GuyNeural, id-ID-GadisNeural, id-ID-ArdiNeural
# Full list: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support#tts
TTS_FREE_VOICE=en-US-AriaNeural

# [OPTIONAL — PAID] D-ID avatar video generation (alternative to fal.ai).
DID_API_KEY=

# ─── App base URL ─────────────────────────────────────────────────────────────
# Dev server runs on port 3001 (see app/package.json -> "dev": "next dev -p 3001").
# Use ngrok / Cloudflare Tunnel + paste the https URL here when working with
# Telegram webhooks locally.
APP_BASE_URL=http://localhost:3001

# ─── Telegram approval bot (optional, FREE) ───────────────────────────────────
# Telegram Bot API is 100% free. Create a bot via @BotFather to get the token.
# Get your chat ID by messaging @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ─── Local provider settings (only used when SCRAPER_PROVIDER=local) ──────────

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
LOCAL_BROWSER_PROFILE_DIR=../data/browser-profile
YTDLP_COOKIES_PATH=../data/cookies/instagram.txt
WHISPER_COMMAND=whisper

# Override the yt-dlp binary used by the TikTok/YouTube providers (optional).
# Default: "yt-dlp" on PATH. On Windows, after `winget install yt-dlp`, the app
# also auto-resolves the WinGet Packages path if the dev server started before
# PATH was refreshed (leave empty to use that behavior).
YTDLP_COMMAND=yt-dlp

# Thumbnails: scraped/imported thumbs are cached under app/public/thumbnails.
# To refresh old rows (SSE): POST /api/videos/backfill-thumbnails (TikTok/YT
# re-fetches via yt-dlp when possible; expired Instagram CDN URLs need re-import).
